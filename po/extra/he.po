#: data/keyboard.metainfo.xml.in:125 data/keyboard.metainfo.xml.in:141
#: data/keyboard.metainfo.xml.in:159
msgid "Minor updates:"
msgstr "עדכונים משניים:"

#: data/keyboard.metainfo.xml.in:47
msgid "Allow assigning Gdk.Key.Tools button"
msgstr ""

#: data/keyboard.metainfo.xml.in:48 data/keyboard.metainfo.xml.in:57
#: data/keyboard.metainfo.xml.in:73 data/keyboard.metainfo.xml.in:82
#: data/keyboard.metainfo.xml.in:95 data/keyboard.metainfo.xml.in:114
#: data/keyboard.metainfo.xml.in:128 data/keyboard.metainfo.xml.in:143
#: data/keyboard.metainfo.xml.in:162
msgid "Updated translations"
msgstr "תרגומים עודכנו"

#: data/keyboard.metainfo.xml.in:91
msgid "Updated shortcut category icons"
msgstr "סמלי קטגוריות קיצורים עודכנו"

#: data/keyboard.metainfo.xml.in:92
msgid "Improved screen reader accessibility"
msgstr "נגישות מקריא המסך השתפרה"

#: data/keyboard.metainfo.xml.in:93
msgid "New shortcut settings for launching dock items"
msgstr "הגדרות קיצור חדשות להפעלת פריטים במעגן"

#: data/keyboard.metainfo.xml.in:94
msgid "Clearer actions for managing keyboard layouts"
msgstr "פעולות ברורות יותר לניהול פריסות מקלדת"

#: data/keyboard.metainfo.xml.in:111
msgid "Fix potential crashes"
msgstr "תוקנו דברים שיכלו לגרום לקריסות"

#: data/keyboard.metainfo.xml.in:112
msgid ""
"Add \"Cycle Windows of application\" and \"Cycle Windows of application "
"backwards\" shortcuts"
msgstr ""
"נוספו הקיצורים „החלפה מעגלית בין חלונות של יישום” ו„החלפה מעגלית בין חלונות "
"של יישום לאחור”"

#: data/keyboard.metainfo.xml.in:113
msgid "Improve experience installing input methods"
msgstr "שופרה החוויה של התקנת שיטות קלט"

#: data/keyboard.metainfo.xml.in:127
msgid "Show the values associated with sliders while dragging"
msgstr "הערכים שקשורים למחווני הגלילה מופיעים בעת גרירה"

#: data/keyboard.metainfo.xml.in:153
msgid "New features:"
msgstr "יכולות חדשות:"

#: data/keyboard.metainfo.xml.in:155
msgid "Revert shortcuts to default"
msgstr "קיצורי הדרך הוחזרו לברירת המחדל"

#: data/keyboard.metainfo.xml.in:156
msgid "Easily disable a shortcut"
msgstr "אפשר להשבית קיצורי דרך בקלות"

#: data/keyboard.metainfo.xml.in:157
msgid "Support Rime input method for Chinese"
msgstr "נוספה תמיכה בשיטת הקלט Rime לסינית"

#: data/keyboard.metainfo.xml.in:161
msgid "Remove custom shortcuts from their menu"
msgstr "הוסרו קיצורי דרך מותאמים אישית מהתפריט שלהם"

