#: data/keyboard.metainfo.xml.in:11
msgid "Configure keyboard behavior, layouts, and shortcuts"
msgstr "Konfigurera tangentbordsbeteende, layouter och genvägar"

#: data/keyboard.metainfo.xml.in:37
msgid "elementary, Inc."
msgstr "elementary, Inc."

#: data/keyboard.metainfo.xml.in:45 data/keyboard.metainfo.xml.in:55
